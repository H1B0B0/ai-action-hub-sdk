  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "ai-seo",
    "actions",
    "chatgpt",
    "gemini",
    "claude",
    "perplexity",
    "cta",
    "llms",
    "llms-txt",
    "schema-org",
    "json-ld",
    "openapi",
    "sdk",
    "nextjs",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
